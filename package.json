:root{--bg:#f7f7f8;--card:#fff;--text:#0b0b0f;--muted:#747782;--line:#e8e8ec;--dark:#050507;--gold:#d7a84a;--green:#14b86a;--red:#e5484d;--shadow:0 24px 80px rgba(0,0,0,.08)}*{box-sizing:border-box}body{margin:0;background:linear-gradient(135deg,#fafafa,#f1f2f4);font-family:Inter,ui-sans-serif,system-ui,-apple-system,Segoe UI,Arial;color:var(--text)}button,input,select{font:inherit}button{border:0;background:#0b0b0f;color:white;border-radius:14px;padding:11px 15px;font-weight:800;display:inline-flex;align-items:center;gap:8px;cursor:pointer;transition:.2s}button:hover{transform:translateY(-1px);box-shadow:0 10px 25px rgba(0,0,0,.12)}button.secondary,.ghost{background:#f0f1f3;color:#111}button.danger{background:#ffe8e8;color:#b4232a}button.link{background:transparent;color:#111;box-shadow:none}input,select{width:100%;border:1px solid var(--line);border-radius:14px;padding:12px;background:white}.brand{display:flex;align-items:center;gap:13px}.brand img{width:92px;height:52px;object-fit:contain;background:#050507;border-radius:10px}.brand b{display:block;font-size:26px;letter-spacing:-1px}.brand span{display:block;font-size:12px;color:#7a7d86}.brand.compact img{width:72px;height:42px}.brand.compact b{font-size:20px}.authPage{min-height:100vh;display:grid;grid-template-columns:1.2fr 430px;gap:40px;align-items:center;padding:55px;overflow:hidden}.hero{background:#050507;color:white;border-radius:34px;padding:46px;box-shadow:var(--shadow);min-height:640px;display:flex;flex-direction:column;justify-content:center;position:relative}.hero:after{content:"";position:absolute;inset:auto -20% -35% auto;width:520px;height:520px;background:radial-gradient(circle,rgba(215,168,74,.35),transparent 60%)}.hero h1{font-size:62px;max-width:720px;line-height:.95;margin:40px 0 18px}.hero p{font-size:18px;color:#d3d5db;max-width:620px}.heroGrid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:30px;max-width:620px}.heroGrid span{border:1px solid rgba(255,255,255,.16);background:rgba(255,255,255,.06);border-radius:18px;padding:18px}.authCard,.panel,.modal{background:rgba(255,255,255,.86);backdrop-filter:blur(16px);border:1px solid rgba(255,255,255,.7);border-radius:28px;box-shadow:var(--shadow)}.authCard{padding:28px;display:grid;gap:14px}.authCard h2{font-size:28px;margin:8px 0}.input{display:flex;align-items:center;gap:8px;border:1px solid var(--line);border-radius:14px;padding:0 12px;background:white}.input input{border:0;padding-left:0}.loader{min-height:100vh;display:grid;place-items:center;align-content:center;gap:18px}.shell{display:grid;grid-template-columns:280px 1fr;min-height:100vh}aside{background:#050507;color:white;padding:24px;display:flex;flex-direction:column;gap:26px;position:sticky;top:0;height:100vh}aside nav{display:grid;gap:8px;overflow:auto}aside nav button{justify-content:flex-start;background:transparent;color:#d7d8dc;border:1px solid transparent}aside nav button.active,aside nav button:hover{background:#fff;color:#050507;box-shadow:none}aside nav svg{width:18px}.userMini{margin-top:auto;border:1px solid rgba(255,255,255,.14);border-radius:20px;padding:14px;display:flex;gap:12px;align-items:center;cursor:pointer}.userMini small{display:block;color:#a4a7b0}main{padding:28px 38px}.top{display:flex;justify-content:space-between;align-items:center;margin-bottom:26px}.top h1{font-size:34px;margin:0}.top p{margin:4px 0 0;color:var(--muted)}.menu{display:none}.welcome{background:#050507;color:white;border-radius:32px;padding:28px;display:flex;justify-content:space-between;align-items:center;margin-bottom:22px}.welcome h2{font-size:36px;margin:0}.welcome p{color:#c9cbd2}.cards{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:22px}.dashCard{background:white;color:#0b0b0f;border-radius:24px;padding:22px;min-height:130px;box-shadow:var(--shadow);display:grid;grid-template-columns:auto 1fr auto;gap:10px;align-items:center;text-align:left}.dashCard svg:first-child{background:#f1f1f2;border-radius:16px;padding:10px;width:48px;height:48px}.dashCard span{font-weight:800}.dashCard b{font-size:32px}.panel{padding:24px;margin-bottom:22px}.panel h2{margin:0 0 16px;font-size:26px}.toolbar{display:flex;justify-content:space-between;gap:14px;align-items:center;margin-bottom:18px}.search{display:flex;align-items:center;gap:8px;background:white;border:1px solid var(--line);border-radius:16px;padding:0 12px;min-width:280px}.search input{border:0}.grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}.jobCard,.person{border:1px solid var(--line);background:white;border-radius:24px;padding:20px;display:grid;gap:10px}.jobCard h3{margin:0;font-size:20px}.jobCard p{display:flex;align-items:center;gap:8px;color:#595d66;margin:0}.jobCard small{color:#777;min-height:24px}.row{display:flex;justify-content:space-between;align-items:center;gap:10px}.actions{display:flex;gap:8px;flex-wrap:wrap}.badge{display:inline-flex;width:max-content;border-radius:999px;padding:6px 10px;background:#eef0f3;color:#333;font-size:12px;font-weight:900}.badge.green{background:#dcfce7;color:#087a3d}.badge.gold{background:#fff3d6;color:#9a6400}.badge.red{background:#ffe1e1;color:#b4232a}.table{display:grid;gap:10px}.tr{display:grid;grid-template-columns:1.2fr 1fr 1fr 1fr auto auto auto;gap:10px;align-items:center;background:white;border:1px solid var(--line);border-radius:18px;padding:12px}.tr span{color:#666}.empty{min-height:260px;display:grid;place-items:center;align-content:center;color:#777}.empty svg{width:60px;height:60px;background:#f0f1f3;border-radius:999px;padding:16px;color:#111}.features{display:flex;gap:10px;flex-wrap:wrap}.features span{background:#f2f2f3;border-radius:999px;padding:10px 14px;font-weight:700}.timeBox{background:white;border:1px solid var(--line);border-radius:22px;padding:20px;margin-bottom:18px}.profile{text-align:center}.profile .info{display:grid;gap:10px;text-align:left;max-width:620px;margin:20px auto}.profile .info p{display:flex;gap:10px;align-items:center;background:white;border:1px solid var(--line);border-radius:16px;padding:13px}.modalBack{position:fixed;inset:0;background:rgba(0,0,0,.48);display:grid;place-items:center;padding:20px;z-index:20}.modal{width:min(760px,96vw);max-height:92vh;overflow:auto;padding:22px}.modalHead{display:flex;justify-content:space-between;align-items:center;margin-bottom:14px}.modalHead h2{margin:0}.form{display:grid;grid-template-columns:1fr 1fr;gap:14px}.field{display:grid;gap:6px;font-weight:700;color:#555}.field span{font-size:13px}.check{grid-column:1/-1;display:flex;gap:10px;align-items:center}.form button{grid-column:1/-1}@media(max-width:1050px){.shell{grid-template-columns:1fr}aside{position:fixed;left:-290px;z-index:10;transition:.2s}aside.open{left:0}.menu{display:inline-flex}.cards,.grid{grid-template-columns:1fr 1fr}.tr{grid-template-columns:1fr}.authPage{grid-template-columns:1fr;padding:24px}.hero{min-height:auto}.hero h1{font-size:42px}}@media(max-width:650px){main{padding:18px}.cards,.grid,.form{grid-template-columns:1fr}.toolbar{flex-direction:column;align-items:stretch}.search{min-width:unset}.top h1{font-size:24px}.welcome{display:grid;gap:16px}.heroGrid{grid-template-columns:1fr}}
